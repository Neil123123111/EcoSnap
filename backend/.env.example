# Backend Environment Variables

# ========================
# DATABASE CONFIGURATION
# ========================
# PostgreSQL connection URL format:
# postgresql://username:password@host:port/database
DATABASE_URL=postgresql://neil@localhost:5432/ecosnap

# ========================
# SERVER CONFIGURATION
# ========================
# Base URL for the backend API
BASE_URL=http://localhost:8001

# ========================
# SECURITY
# ========================
# Secret key for JWT token signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=super-secret-key-change-in-production

# ========================
# FILE UPLOAD
# ========================
# Directory for uploaded files (relative to backend root)
UPLOAD_DIR=app/static/upload

# ========================
# DEBUG MODE
# ========================
# Set to False in production
DEBUG=True

# ========================
# IQAIR AIRVISUAL
# ========================
# Free/community API key from IQAir AirVisual
IQAIR_API_KEY=
IQAIR_BASE_URL=https://api.airvisual.com/v2
OPEN_METEO_AIR_QUALITY_BASE_URL=https://air-quality-api.open-meteo.com/v1

# ========================
# ROBOFLOW TRAINING
# ========================
# API key from Roboflow account settings
ROBOFLOW_API_KEY=

# Workspace slug, for example: my-workspace
ROBOFLOW_WORKSPACE=

# Project slug, for example: ecosnap-trash
ROBOFLOW_PROJECT=

# Dataset version number on Roboflow
ROBOFLOW_VERSION=1

# Export format for Roboflow dataset download.
# Use "folder" for classification datasets, or "yolov8" for detection datasets.
ROBOFLOW_FORMAT=folder

# Trained classification model used by /report/classify
TRAINED_CLASSIFIER_MODEL_PATH=runs/ecosnap_8_classes/weights/best.pt
